pipeline {
    agent any
    
    environment {
        // الـ Credentials الأساسية من جينكينز
        AWS_ACCESS_KEY_ID     = credentials('AWS_ACCESS_KEY')
        AWS_SECRET_ACCESS_KEY = credentials('AWS_SECRET_KEY')
        ANSIBLE_HOST_KEY_CHECKING = 'False'
    }
    
    stages {
        // المرحلة الأولى: سحب الكود من GitHub (Continuous Integration)
        stage('CI: Checkout') {
            steps {
                checkout scm
            }
        }

        // المرحلة الثانية: بناء البنية التحتية (Infrastructure as Code)
        stage('CD: Infrastructure Provisioning') {
            steps {
                sh 'terraform init'
                sh 'terraform apply -auto-approve'
                
                script {
                    // استخراج الـ IPs لاستخدامها في المراحل التالية
                    env.BASTION_IP = sh(script: "terraform output -raw bastion_public_ip", returnStdout: true).trim()
                    env.APP_IP = sh(script: "terraform output -raw app_private_ip", returnStdout: true).trim()
                }
            }
        }

        // المرحلة الثالثة: تحديث الـ Inventory
        stage('CD: Update Inventory') {
            steps {
                sh '''
                    echo "[bastion_host]" > ansible/inventory/hosts.ini
                    echo "${BASTION_IP} ansible_user=ubuntu" >> ansible/inventory/hosts.ini
                    echo "\n[app_server]" >> ansible/inventory/hosts.ini
                    echo "${APP_IP} ansible_user=ubuntu" >> ansible/inventory/hosts.ini
                '''
            }
        }
        
        // المرحلة الرابعة: تهيئة السيرفرات (Configuration Management)
        stage('CD: Configuration & Deployment') {
            steps {
                dir('ansible') {
                    withCredentials([sshUserPrivateKey(credentialsId: 'aws-ssh-key', keyFileVariable: 'MY_KEY')]) {
                        script {
                            // إعداد الـ ProxyJump للوصول للسيرفر الـ Private
                            def sshArgs = "-o ProxyCommand='ssh -W %h:%p -q ubuntu@${env.BASTION_IP} -i ${MY_KEY} -o StrictHostKeyChecking=no' -o StrictHostKeyChecking=no"
                            
                            // تشغيل الـ Playbook لتثبيت Docker أو أي تطبيق آخر
                            sh """
                                ansible-playbook -i inventory/hosts.ini playbooks/install_docker.yml \
                                -u ubuntu \
                                --private-key=${MY_KEY} \
                                --ssh-common-args="${sshArgs}"
                            """
                        }
                    }
                }
            }
        }
    }
    
    post {
        success {
            echo "CI/CD Pipeline Completed Successfully!"
        }
        failure {
            echo "Pipeline Failed. Check the logs."
        }
    }
}